# 桌宠 Vite 配置模板
# 复制此文件为 .env，填入你自己的值

# ── 必填 ────────────────────────────────────────────────────────────────────
# Hermes API 密钥（需与 ~/.hermes/.env 里的 API_SERVER_KEY 保持一致）
VITE_HERMES_KEY=change-me-local-dev

# ── 可选：飞书集成 ───────────────────────────────────────────────────────────
# 飞书机器人的会话 openChatId（在飞书开放平台 → 机器人 → 查看详情里找）
# 留空则禁用「在飞书找麦麦」按钮
VITE_FEISHU_CHAT_ID=

# 你的飞书 open_id（用作与飞书 DM 共享上下文的 session key）
# 获取方式：hermes feishu whoami
VITE_HERMES_SESSION_KEY=

# ── 可选：工作台地址 ─────────────────────────────────────────────────────────
# 双击菜单「打开工作台」指向的 URL
VITE_WORKBENCH_URL=http://localhost:3002/
