{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:4100/*" },
        { "url": "http://localhost:8642/*" }
      ]
    }
  ]
}